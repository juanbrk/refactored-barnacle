{
  "name": "finance-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma de gestión de finanzas hogareñas",
  "workspaces": [
    "frontend",
    "backend/functions",
    "shared"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run serve --workspace=backend/functions",
